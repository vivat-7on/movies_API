POSTGRES_USER=auth
POSTGRES_PASSWORD=change-me
POSTGRES_DB=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

JWT_PRIVATE_KEY_PATH=/secrets/jwt/private.pem
JWT_PUBLIC_KEY_PATH=/secrets/jwt/public.pem
JWT_ALGORITHM=RS256
ACCESS_TOKEN_TTL_MINUTES=10
REFRESH_TOKEN_TTL_DAYS=7
DEFAULT_ROLE_NAME=user
DEBUG=true

OTLP_ENDPOINT=http://jaeger:4317

YANDEX_AUTHORIZE_URI=https://oauth.yandex.ru/authorize
YANDEX_TOKEN_URI=https://oauth.yandex.ru/token
YANDEX_USER_INFO_URI=https://login.yandex.ru/info
YANDEX_CLIENT_ID=12345
YANDEX_CLIENT_SECRET=secret
YANDEX_REDIRECT_URI=http://losalhost/login

REDIS_HOST=redis
REDIS_PORT=6379

AUTH_SERVICE_TOKEN=your-token