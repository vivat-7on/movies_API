### Python ###
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
*.egg

# Virtual environment
venv/
.venv/  # Common name for virtual environments

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*,cover
.hypothesis/

# Translations
*.mo
*.pot

# Misc
*.log
.env # often sensitive data, should be ignored

### PyCharm ###
# PyCharm project files (mostly in .idea folder)
.idea/
# Some files within .idea are important to share with the team, e.g., vcs.xml,
# so a more specific ignore might be used, but generally ignoring the whole folder is simpler.
# If you want to share specific files, you can use more granular rules:
# .idea/*
# !.idea/vcs.xml
# !.idea/encodings.xml
# !.idea/workspace.xml # But this is personal workspace settings, usually ignored

# Specific OS files
.DS_Store # macOS
.project # Eclipse
/.venv/
/.env
